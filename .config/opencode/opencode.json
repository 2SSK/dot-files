{
  "$schema": "https://opencode.ai/config.json",
  "agent": {},
  "command": {
    "git": {
      "agent": "build",
      "description": "Creates a git commit message",
      "template": "Create a concise conventional commit message in plain text. Check the staging area for more information. if needed, use dashes as bullets to list multiple changes. Don't capitalize the first character."
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "filesystem": {
      "command": [
        "npx",
        "@modelcontextprotocol/server-filesystem",
        "/home/ssk"
      ],
      "enabled": true,
      "type": "local"
    },
    "postgres": {
      "command": [
        "npx",
        "-y",
        "@henkey/postgres-mcp-server",
        "--connection-string",
        "{env:POSTGRES_DATABASE_URI}"
      ],
      "enabled": false,
      "type": "local"
    },

    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=llkyvmrsadrwiawbfcyt",
      "enabled": false
    },
    "prometheus": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "-p",
        "@wkronmiller/prometheus-mcp-server",
        "prometheus-mcp-server"
      ],
      "environment": {
        "PROMETHEUS_URL": "{env:PROMETHEUS_URL}"
      },
      "enabled": true
    },
    "grafana": {
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "{env:GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_TOKEN}"
      },
      "enabled": true
    },
    "superset": {
      "type": "remote",
      "url": "http://20.244.81.6/mcp",
      "enabled": true,
      "headers": {
        "X-API-Key": "ecavo_admin-api-key"
      }
    }
  }
}
